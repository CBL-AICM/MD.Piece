    { "src": "/admin-stats/(.*)", "dest": "api/index.py" },
    { "src": "/admin-stats", "dest": "api/index.py" },
    { "src": "/events/(.*)", "dest": "api/index.py" },
    { "src": "/events", "dest": "api/index.py" },
    { "src": "/rewards/(.*)", "dest": "api/index.py" },
    { "src": "/rewards", "dest": "api/index.py" },
    { "src": "/api/github-token", "dest": "api/github-token.js" },
    { "src": "/admin", "dest": "frontend/admin.html" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
