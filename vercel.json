{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb", "maxDuration": 60 }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/github-token.js",
      "use": "@vercel/node"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/patients/(.*)", "dest": "api/index.py" },
    { "src": "/patients", "dest": "api/index.py" },
    { "src": "/doctors/(.*)", "dest": "api/index.py" },
    { "src": "/doctors", "dest": "api/index.py" },
    { "src": "/symptoms/(.*)", "dest": "api/index.py" },
    { "src": "/symptoms", "dest": "api/index.py" },
    { "src": "/education/(.*)", "dest": "api/index.py" },
    { "src": "/education", "dest": "api/index.py" },
    { "src": "/emotions/(.*)", "dest": "api/index.py" },
    { "src": "/emotions", "dest": "api/index.py" },
    { "src": "/medications/(.*)", "dest": "api/index.py" },
    { "src": "/medications", "dest": "api/index.py" },
    { "src": "/reports/(.*)", "dest": "api/index.py" },
    { "src": "/reports", "dest": "api/index.py" },
    { "src": "/triage/(.*)", "dest": "api/index.py" },
    { "src": "/triage", "dest": "api/index.py" },
    { "src": "/drug-search/(.*)", "dest": "api/index.py" },
    { "src": "/drug-search", "dest": "api/index.py" },
    { "src": "/diseases/(.*)", "dest": "api/index.py" },
    { "src": "/diseases", "dest": "api/index.py" },
    { "src": "/xiaohe/(.*)", "dest": "api/index.py" },
    { "src": "/xiaohe", "dest": "api/index.py" },
    { "src": "/records/(.*)", "dest": "api/index.py" },
    { "src": "/records", "dest": "api/index.py" },
    { "src": "/research/(.*)", "dest": "api/index.py" },
    { "src": "/research", "dest": "api/index.py" },
    { "src": "/auth/(.*)", "dest": "api/index.py" },
    { "src": "/auth", "dest": "api/index.py" },
    { "src": "/alerts/(.*)", "dest": "api/index.py" },
    { "src": "/alerts", "dest": "api/index.py" },
    { "src": "/doctor-notes/(.*)", "dest": "api/index.py" },
    { "src": "/doctor-notes", "dest": "api/index.py" },
    { "src": "/medication-changes/(.*)", "dest": "api/index.py" },
    { "src": "/medication-changes", "dest": "api/index.py" },
    { "src": "/labs/(.*)", "dest": "api/index.py" },
    { "src": "/labs", "dest": "api/index.py" },
    { "src": "/diet/(.*)", "dest": "api/index.py" },
    { "src": "/diet", "dest": "api/index.py" },
    { "src": "/admissions/(.*)", "dest": "api/index.py" },
    { "src": "/admissions", "dest": "api/index.py" },
    { "src": "/reminders/(.*)", "dest": "api/index.py" },
    { "src": "/reminders", "dest": "api/index.py" },
    { "src": "/timeline/(.*)", "dest": "api/index.py" },
    { "src": "/timeline", "dest": "api/index.py" },
