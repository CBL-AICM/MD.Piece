# 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# AI 症狀分析（選填，未設定時使用備用分析）
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM Provider 切換
# - ollama:    本地開發用 Ollama（預設、零成本、資料不出本機）
# - groq:      雲端部署用 Groq 免費 API（速度快）
# - anthropic: 雲端部署用 Claude API（需要 ANTHROPIC_API_KEY；推薦給 Vercel）
#
# 自動 fallback：主 provider 失敗會依序嘗試 anthropic → groq → ollama，
# 只要任一個 provider 的 key 有設、或本地 Ollama 有跑，就能正常運作。
LLM_PROVIDER=ollama
# Ollama 設定（LLM_PROVIDER=ollama 時使用）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TEXT_MODEL=qwen2.5:7b
# OLLAMA_VISION_MODEL=llava:7b
# Groq 設定（LLM_PROVIDER=groq 或作為 fallback 時使用，註冊：https://console.groq.com/keys）
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile
# Anthropic 設定（LLM_PROVIDER=anthropic 或作為 fallback 時使用）
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=1024

# Google Cloud Vision OCR（藥單 / 藥袋小字辨識最準的選項，月 1000 次免費）
# 申請：GCP Console → APIs & Services → 啟用 Cloud Vision API → 建立 API Key
# 設定後藥袋辨識會優先用這個（OCR 純文字 → Haiku 抽欄位），失敗才 fallback 到 LLM vision
# GOOGLE_VISION_API_KEY=your-google-vision-api-key

# 應用程式
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-here

# 資料庫
DATABASE_URL=sqlite:///./md_piece.db

# 其他設定
# CORS_ORIGINS=http://localhost:3000
