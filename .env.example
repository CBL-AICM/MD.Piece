# 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# AI 症狀分析（選填，未設定時使用備用分析）
ANTHROPIC_API_KEY=your-anthropic-api-key

# 應用程式
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-here

# 資料庫
DATABASE_URL=sqlite:///./md_piece.db

# 其他設定
# CORS_ORIGINS=http://localhost:3000

# ─── 認證 ─────────────────────────────────────────────
# JWT 簽章金鑰（正式環境請改成隨機長字串）
JWT_SECRET=md-piece-dev-secret-change-me
# JWT 有效時數
JWT_EXPIRE_HOURS=24

# 是否允許醫師自助註冊（true / false）
ALLOW_DOCTOR_SELF_REGISTER=true

# 啟動時若資料庫沒有任何醫師帳號，會用以下參數建立一組初始醫師
INITIAL_DOCTOR_USERNAME=doctor
INITIAL_DOCTOR_PASSWORD=mdpiece2026
INITIAL_DOCTOR_NICKNAME=測試醫師
