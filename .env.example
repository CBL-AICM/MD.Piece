# 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# AI 症狀分析（選填，未設定時使用備用分析）
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM Provider 切換
# - ollama: 本地開發用 Ollama（預設）
# - groq:   雲端部署用 Groq 免費 API（推薦給 Vercel 部署）
LLM_PROVIDER=ollama
# Ollama 設定（LLM_PROVIDER=ollama 時使用）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TEXT_MODEL=qwen2.5:7b
# OLLAMA_VISION_MODEL=llava:7b
# Groq 設定（LLM_PROVIDER=groq 時必填，註冊：https://console.groq.com/keys）
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# 應用程式
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-here

# 資料庫
DATABASE_URL=sqlite:///./md_piece.db

# 其他設定
# CORS_ORIGINS=http://localhost:3000
