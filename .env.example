# 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# AI 症狀分析（選填，未設定時使用備用分析）
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM Provider 切換
# - ollama:    本地開發用 Ollama（預設、零成本、資料不出本機）
# - groq:      雲端部署用 Groq 免費 API（速度快）
# - anthropic: 雲端部署用 Claude API（需要 ANTHROPIC_API_KEY；推薦給 Vercel）
# - gemini:    Google Gemini API（免費 tier 高品質、繁中佳）
#
# 自動 fallback：主 provider 失敗會依序嘗試 gemini → anthropic → groq → ollama，
# 只要任一個 provider 的 key 有設、或本地 Ollama 有跑，就能正常運作。
LLM_PROVIDER=ollama
# Ollama 設定（LLM_PROVIDER=ollama 時使用）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TEXT_MODEL=qwen2.5:7b
# OLLAMA_VISION_MODEL=llava:7b
# Groq 設定（LLM_PROVIDER=groq 或作為 fallback 時使用，註冊：https://console.groq.com/keys）
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile
# Anthropic 設定（LLM_PROVIDER=anthropic 或作為 fallback 時使用）
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=1024

# Google Cloud Vision OCR（藥單 / 藥袋小字辨識最準的選項，月 1000 次免費）
# 申請：GCP Console → APIs & Services → 啟用 Cloud Vision API → 建立 API Key
# 設定後藥袋辨識會優先用這個（OCR 純文字 → Haiku 抽欄位），失敗才 fallback 到 LLM vision
# GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Gemini API（免費高品質 fallback；繁中品質遠優於 Llama）
# 申請：https://aistudio.google.com/apikey（Google 帳號登入即可）
# 免費 tier：1500 req/day + 15 RPM；fallback chain 會插在 anthropic 之前
# 注意：免費 tier 的請求可能被 Google 用於模型訓練（付費 tier 不會），
#       醫療資料敏感者請接受這個 ToS 後再啟用
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash

# 應用程式
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-here

# JWT — Phase 1a 後新增（Issue #388）
# 產生：python -c "import secrets; print(secrets.token_urlsafe(48))"
# 至少 16 字元，建議 64 字元。Vercel / production 必填，否則 /auth/login 會 500。
JWT_SECRET=replace-with-random-64char-string

# 資料庫
DATABASE_URL=sqlite:///./md_piece.db

# Web Push 通知（VAPID）
# 未設定時手機推播停用、僅站內通知運作；前端會自動把「啟用推播」按鈕灰掉。
# 產生新 key：`npx web-push generate-vapid-keys`（Public/Private 都是 URL-safe base64）
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT_EMAIL=mailto:admin@mdpiece.life

# 排程派送（Web Push 提醒）
# 提醒要在「App 沒開」時也能推播，需有排程定時打 dispatch 端點：
#   - Vercel 原生 Cron（只發 GET）：設 CRON_SECRET，Vercel 會自動帶
#     Authorization: Bearer ${CRON_SECRET}，並在 vercel.json 加 crons 指向
#     GET /reminders/cron/dispatch。
#   - 外部排程（cron-job.org / GitHub Actions…）：設 CRON_TOKEN，呼叫時帶
#     header X-Cron-Token: ${CRON_TOKEN}（GET /reminders/cron/dispatch）。
# 兩者皆未設時端點開放（僅建議本地測試用）。
# CRON_SECRET=
# CRON_TOKEN=

# 其他設定
# CORS_ORIGINS=http://localhost:3000
